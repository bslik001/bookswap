# URL de l'API BookSwap
# - Dev local : http://<ton-IP-LAN>:3000/api  (pas localhost, sinon le device ne resoudra pas)
# - Staging  : https://bookswap-api-2osb.onrender.com/api
EXPO_PUBLIC_API_URL=https://bookswap-api-2osb.onrender.com/api

# Mode demo : affiche un hint "Code OTP : 1234" sur l'ecran de verification
# (a coupler avec DEMO_MODE=true cote backend)
EXPO_PUBLIC_DEMO_MODE=true

# Sentry (optionnel)
EXPO_PUBLIC_SENTRY_DSN=
