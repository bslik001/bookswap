# Base de donnees (utilise les credentials du docker-compose par defaut)
DATABASE_URL=postgresql://bookswap:bookswap@localhost:5432/bookswap

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_64_chars

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase (Cloud Messaging)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Africa's Talking (SMS OTP)
AT_API_KEY=your_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=BookSwap

# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081
